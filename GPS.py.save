import rclpy
from rclpy.node import Node
from std_msgs.msg import Float32MultiArray
import serial
from pyubx2 import UBXReader, UBXMessage
import socket

class GPS(Node):
    def __init__(self):
        super().__init__('GPS')
        
        self.publisher_ = self.create_publisher(Float32MultiArray, 'gps', 10)

        port = '/dev/ttyACM0'
        self.stream = serial.Serial(port, baudrate=9600, timeout=1)
        
        # --- שתי שורות ההגנה שמונעות את הקריסה ---
        self.stream.reset_input_buffer()  # מנקה את הזבל מהחיבורים הישנים
        self.ubr = UBXReader(self.stream, quitonerror=2) # מתעלם מביטים שבורים במקום לקרוס

        set_msg = UBXMessage('CFG', 'CFG-RATE', 1, measRate=200, navRate=1, timeRef=0)
        self.stream.write(set_msg.serialize())

        self.laptop_ip = '192.168.2.2'  # הכתובת של ה-ROV
        self.udp_port = 27000           # הפורט שנייעד לזה
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

        self.timer = self.create_timer(0.2, self.read_gps_data)

    def read_gps_data(self):
        try:
            raw_data, msg = self.ubr.read()
            if msg and hasattr(msg, 'identity') and msg.identity == 'NAV-PVT':
                
                lat_decimal = msg.lat / 1e7 if abs(msg.lat) > 90 else msg.lat
                lon_decimal = msg.lon / 1e7 if abs(msg.lon) > 180 else msg.lon
                alt = msg.height / 1000.0
                fix = msg.fixType
                nmea_fix = 1 if fix >= 2 else 0
                
                self.publisher_.publish(Float32MultiArray(data=[fix, lat_decimal, lon_decimal, alt]))

                lat_abs = abs(lat_decimal)
                lon_abs = abs(lon_decimal)
                
                lat_nmea = f"{int(lat_abs):02d}{(lat_abs % 1 * 60):07.4f}"
                lat_dir = 'N' if lat_decimal >= 0 else 'S'
                
                lon_nmea = f"{int(lon_abs):03d}{(lon_abs % 1 * 60):07.4f}"
                lon_dir = 'E' if lon_decimal >= 0 else 'W'
                
                nmea_sentence = f"GNGGA,120000.00,{lat_nmea},{lat_dir},{lon_nmea},{lon_dir},{nmea_fix},08,0.9,{alt:.1f},M,0.0,M,,"
                
                checksum = 0
                for char in nmea_sentence:
                    checksum ^= ord(char)
                
                full_nmea = f"${nmea_sentence}*{checksum:02X}\r\n"
                
                self.sock.sendto(full_nmea.encode('ascii'), (self.laptop_ip, self.udp_port))

        except Exception as e:
            # במקום לקרוס, הוא פשוט יכתוב אזהרה וימשיך
            self.get_logger().warn(f"Ignored minor error: {e}")

    def destroy_node(self):
        super().destroy_node()
        if hasattr(self, 'stream'):
            self.stream.close()
        if hasattr(self, 'sock'):
            self.sock.close()

def main(args=None):
    rclpy.init(args=args)
    gps_node = GPS()
    try:
        rclpy.spin(gps_node)
